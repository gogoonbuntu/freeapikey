rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Users can only access their own data (recursive — covers all nested paths)
    match /users/{userId}/{allPaths=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Also allow accessing the user document itself
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
  }
}
